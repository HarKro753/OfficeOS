# Compose
COMPOSE_PROJECT_NAME=officeos

# Postgres
POSTGRES_DB=officeos
POSTGRES_USER=officeos
POSTGRES_PASSWORD=officeos_dev_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://officeos:officeos_dev_password@postgres:5432/officeos

# MinIO / S3-compatible storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=officeos
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin_dev_password
S3_PRESIGN_EXPIRES_SECONDS=900

# Backend
BACKEND_PORT=8000
APP_ENV=development
APP_SECRET_KEY=replace-with-a-long-random-secret
ADMIN_BOOTSTRAP_TOKEN=replace-with-one-time-bootstrap-token
PUBLIC_APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
MAGIC_LINK_EXPIRES_MINUTES=30
SESSION_EXPIRES_DAYS=30

# Dashboard
DASHBOARD_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
